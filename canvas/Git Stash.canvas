		{"id":"edge-center-notignore","fromNode":"stash-center","fromSide":"top","toNode":"stash-not-ignore","toSide":"bottom"},
		{"id":"edge-cmds-popapply","fromNode":"stash-cmds","fromSide":"right","toNode":"stash-pop-apply","toSide":"left"},
