		{"id":"edge-example-branch","fromNode":"stash-example","fromSide":"bottom","toNode":"stash-branch-worktree","toSide":"top"},
		{"id":"edge-branch-pitfall","fromNode":"stash-branch-worktree","fromSide":"right","toNode":"stash-pitfall","toSide":"left"},
