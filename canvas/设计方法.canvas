		{
			"id":"26abb054854b042b",
			"type":"text",
			"text":" export type UUID = `${string}-${string}-${string}-${string}-${string}`;\n\n  export function asUUID(id: string): UUID {\n    if (!id || !/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(id)) {\n      throw new Error(`Invalid UUID format: ${id}`);\n    }\n    return id as UUID;\n  }",
