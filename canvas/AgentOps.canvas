		{"id":"edge-hooks-detail","fromNode":"agentops-hooks","fromSide":"bottom","toNode":"agentops-hooks-detail","toSide":"top"},
		{"id":"edge-flywheel-detail","fromNode":"agentops-flywheel","fromSide":"right","toNode":"agentops-flywheel-detail","toSide":"left"},
		{"id":"edge-loop-detail","fromNode":"agentops-loop","fromSide":"bottom","toNode":"agentops-loop-detail","toSide":"top"},
		{"id":"edge-git-loop","fromNode":"agentops-git","fromSide":"bottom","toNode":"agentops-loop","toSide":"top"},
		{"id":"edge-skills-hooks","fromNode":"agentops-skills","fromSide":"right","toNode":"agentops-hooks","toSide":"left"},
		{"id":"edge-hooks-loop","fromNode":"agentops-hooks","fromSide":"left","toNode":"agentops-loop","toSide":"right"},
		{"id":"edge-flywheel-center","fromNode":"agentops-flywheel","fromSide":"top","toNode":"agentops-center","toSide":"bottom"},
		{"id":"edge-source-center","fromNode":"agentops-source","fromSide":"top","toNode":"agentops-center","toSide":"bottom"}
	],
