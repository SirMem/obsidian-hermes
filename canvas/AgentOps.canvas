		{"id":"edge-center-loop","fromNode":"agentops-center","fromSide":"left","toNode":"agentops-loop","toSide":"right"},
		{"id":"edge-git-detail","fromNode":"agentops-git","fromSide":"bottom","toNode":"agentops-git-detail","toSide":"top"},
		{"id":"edge-value-detail","fromNode":"agentops-value","fromSide":"right","toNode":"agentops-value-detail","toSide":"left"},
